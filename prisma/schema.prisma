generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. Leads Table
model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String
  createdAt DateTime @default(now())
}

// 2. Insights / Blogs Table
model Insights {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String
  imageUrl  String?
  category Category @default(ARCHITECTURE)  
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// 3. Careers / Jobs Table
model Job {
  id          String           @id @default(cuid())
  title       String
  department  String
  location    String
  type        String
  description String           @db.Text  
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  
  applications JobApplication[] 
}
model JobApplication {
  id        String   @id @default(cuid())
  name      String
  email     String
  resumeUrl String?
  createdAt DateTime @default(now())
  
  // Relation: Har application ek specific Job se judegi
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
}
enum Category {
  ARCHITECTURE
  ENGINEERING
  SECURITY
}